# Variables de entorno para The Lua Tsuki Show
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio (ya está en .gitignore).
#
# Para configurar la API key de Gemini, también puedes añadirla directamente
# en ~/.zshrc o ~/.bashrc:
#   export GEMINI_API_KEY=tu_clave_aqui

# ─────────────────────────────────────────────────────────────────
# Google Gemini API  (Imagen 3 + Veo 2)
# Obtén tu clave en: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────────────────────────────────────────
# OpenClaw Gateway (si usas modo remoto)
# ─────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_PASSWORD=
